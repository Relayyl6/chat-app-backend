# Database
MONGODB_URI=mongodb://localhost:27017
DB_NAME=chat_app

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=production

# API Configuration (for production on Render)
API_URL=https://chat-app-backend-5rha.onrender.com
FRONTEND_URL=https://your-frontend-url.vercel.app

# CORS Origins (for production - remove localhost for Render)
ALLOWED_ORIGINS=https://your-frontend-url.vercel.app,https://chat-app-backend-5rha.onrender.com
